# rynk.ai — environment variables
# Copy this file to .env and fill values. NEVER commit .env.

# ─── Required for all LLM agents (Layers 1, 2, 3, 5) ──────────────────────────
ANTHROPIC_API_KEY=

# ─── Layer 1 (Audit Agent) ────────────────────────────────────────────────────
# Crawl4AI — self-hosted, free crawler with JS rendering (Playwright)
# Setup: docker run -d -p 11235:11235 --name crawl4ai unclecode/crawl4ai:latest
# Leave as default unless running on a different host/port.
CRAWL4AI_BASE_URL=http://localhost:11235

# Google PageSpeed Insights — performance metrics (free)
# Get a key: https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
PAGESPEED_API_KEY=

# SerpAPI — SERP features + AI Overview detection
# Get a key: https://serpapi.com
SERPAPI_API_KEY=

# ─── Optional overrides ───────────────────────────────────────────────────────
# MODEL=claude-sonnet-4-6
# LOG_LEVEL=info               # debug | info | warn | error
# MAX_OUTPUT_TOKENS=64000
# CRAWL_PAGE_LIMIT=300         # safety cap for crawler
# DRY_RUN=false                # if true, agents log planned actions without API calls
